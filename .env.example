# Copie para .env na raiz deste projeto (não commite o .env), ou use ``databricks/.env`` na raiz do repo.
# Ou defina NUVEM_DOTENV_PATH apontando para um .env existente (caminho absoluto).
databricks_host=dbc-xxxx.cloud.databricks.com
databricks_http_path=/sql/1.0/warehouses/xxxxxxxx
databricks_token=dapixxxxxxxx

# Opcional: tela de login no dashboard (Streamlit). Se vazio, o painel abre sem senha.
# DASHBOARD_USER=operacao
# DASHBOARD_PASSWORD=defina_uma_senha_forte

# Opcional (aba Argentina): mais grupos no OR do SQL, além do JSON e do código (_EXTRA_GRUPOS_ARGENTINA_TEMP).
# NE_FILTRO_GRUPO_EXTRA_ARGENTINA=Outro Grupo,Equipe X

# Opcional (só aba/modelo Argentina): força ticket_id na query (OR com grupo). Não afeta Brasil.
# Pode repetir IDs em tabs.argentina.incluir_ticket_ids no JSON (mesmo efeito, mesclado sem duplicar).
# NE_INCLUIR_TICKET_IDS=7268849,1234567
