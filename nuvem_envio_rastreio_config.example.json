{
  "_instrucoes": "Copie para nuvem_envio_rastreio_config.json. filtro_grupo_contem: OR no nome do grupo Zendesk (ex.: Argentina inclui Knowledge Management no exemplo). Código também injeta _EXTRA_GRUPOS_ARGENTINA_TEMP em nuvem_envio_rastreio.py (temporário).",
  "catalog_schema": "seu_catalogo.seu_schema_zendesk",
  "dashboard_base_url": "",
